[user]
    email = bryleyhayter@gmail.com
    name = Bryley Hayter

[pull]
    rebase = true
    ff = only

[merge]
    tool = nvimdiff
    conflictstyle = diff3

[diff]
    tool = nvim_difftool

[difftool]
    prompt = false

[difftool "nvim_difftool"]
    cmd = nvim -R -c \"packadd nvim.difftool\" -d \"$LOCAL\" \"$REMOTE\"

[alias]
    dt = difftool --dir-diff

[mergetool]
    keepBackup = false

[init]
    defaultBranch = main

[core]
    pager = less -FRX
