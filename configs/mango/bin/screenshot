#!/usr/bin/env bash
set -euo pipefail

mode="${1:-region}"
out_dir="${XDG_SCREENSHOTS_DIR:-$HOME/Pictures/Screenshots}"
mkdir -p "$out_dir"

file="$out_dir/$(date +'%Y-%m-%d_%H-%M-%S').png"

notify() {
  if command -v notify-send >/dev/null 2>&1; then
    notify-send "Screenshot" "$1"
  fi
}

copy_file() {
  if command -v wl-copy >/dev/null 2>&1; then
    wl-copy --type image/png < "$1"
  fi
}

case "$mode" in
  full)
    grim "$file"
    ;;
  region)
    geometry="$(slurp || true)"
    [ -n "$geometry" ] || exit 0
    grim -g "$geometry" "$file"
    ;;
  copy-full)
    tmp="$(mktemp --suffix=.png)"
    trap 'rm -f "$tmp"' EXIT
    grim "$tmp"
    copy_file "$tmp"
    notify "Copied full screenshot"
    exit 0
    ;;
  copy-region)
    geometry="$(slurp || true)"
    [ -n "$geometry" ] || exit 0
    tmp="$(mktemp --suffix=.png)"
    trap 'rm -f "$tmp"' EXIT
    grim -g "$geometry" "$tmp"
    copy_file "$tmp"
    notify "Copied region screenshot"
    exit 0
    ;;
  *)
    echo "usage: screenshot [full|region|copy-full|copy-region]" >&2
    exit 2
    ;;
esac

copy_file "$file"
notify "Saved + copied: $file"
printf '%s\n' "$file"
