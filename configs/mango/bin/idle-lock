#!/usr/bin/env bash
set -euo pipefail

if pgrep -x swaylock >/dev/null 2>&1; then
  exit 0
fi

log_dir="${XDG_STATE_HOME:-$HOME/.local/state}/mango"
mkdir -p "$log_dir"

swaylock_args=(
  --daemonize
  --ignore-empty-password
  --indicator-radius 120
  --indicator-thickness 8
  --inside-color 00000088
  --ring-color cba6f7ff
  --key-hl-color a6e3a1ff
  --bs-hl-color f38ba8ff
  --text-color cdd6f4ff
  --line-color 00000000
  --separator-color 00000000
)

if [ -f "$HOME/wallpaper" ]; then
  swaylock_args+=(--image "$HOME/wallpaper" --scaling fill)
else
  swaylock_args+=(--color 11111b)
fi

exec swaylock "${swaylock_args[@]}" >>"$log_dir/swaylock.log" 2>&1
